# Copier en `.env` sur le Pi (jamais commité). Toutes les valeurs ont un
# défaut raisonnable dans le code (cf. lib/wakeTargets.ts, lib/llamaCpp.ts,
# lib/kaliSleepScheduler.ts) — ne définir ici que ce qui diffère du défaut.

# Port du service Kibana/Elastic sur Kali (défaut : 5601)
# KALI_SERVICE_PORT=5601

# Backend LLM de Gabrielle : llama.cpp (llama-server, API compatible OpenAI),
# sur le Pi lui-même — défaut 127.0.0.1:8080 si lancé en sibling du conteneur
# Next.js. RAG géré côté serveur llama.cpp, pas dans ce dépôt.
# GABRIELLE_LLAMACPP_URL=http://127.0.0.1:8080
# GABRIELLE_MODEL=qwen2.5-0.5b-instruct

# SSH vers Kali (déclenchement systemctl suspend)
# KALI_SSH_USER=vincent
# KALI_SSH_KEY_PATH=/root/.ssh/id_ed25519_kali

# Embed monitoring public (Grafana/Kibana curé et anonymisé) — vide tant que
# non configuré, cf. components/MonitoringEmbed.tsx
# NEXT_PUBLIC_MONITORING_EMBED_URL=
